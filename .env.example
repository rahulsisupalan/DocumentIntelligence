# ============================================================
# .env.example — Environment Variable Template
# ============================================================
# ✅ This file IS committed to git. It shows all required
#    variables without any real values.
#
# To use: copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# GCP Project
PROJECT_ID=your-gcp-project-id
REGION=us-central1
LOCATION=us-central1
ENV=dev

# Artifact Registry
REPO=services

# Pub/Sub Topics
INVOICE_TOPIC=process-invoice
CONTRACT_TOPIC=process-contract
DEAD_LETTER_TOPIC=dead-letter-topic
COMPLIANCE_TOPIC=process-compliance
STORAGE_TOPIC=route-to-storage

# Firestore
FIRESTORE_COLLECTION=review-queue

# BigQuery
BQ_DATASET=document_intelligence
BQ_TABLE=extractions_dev

# Vertex AI
VECTOR_SEARCH_INDEX=doc_embeddings_index

# Worker Config
CONFIDENCE_THRESHOLD=0.80
